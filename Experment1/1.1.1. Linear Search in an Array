#include <stdio.h>

int main ()
{
	int n , key;
	//read size of array
	scanf("%d", &n);

	int arr[n];
// read arr element
	for (int i = 0; i < n; i++)
		{
			scanf("%d",&arr[i]);
		}
//read element to search
	scanf("%d",&key);

	for(int i =0; i<n; i++)
		{
			if (arr[i] == key)
			{
				printf("found at position %d\n",i);
				return 0;
			}
		}
	printf("%d not found\n",key);
	return 0;
}
